---
---

<header class="nav-wrapper">
  <nav class="navbar" id="main-nav">
    <a href="#home"     class="nav-link" data-section="home">Home</a>
    <span class="nav-sep" aria-hidden="true"></span>
    <a href="#projects" class="nav-link" data-section="projects">Projects</a>
    <span class="nav-sep" aria-hidden="true"></span>
    <a href="#contact"  class="nav-link" data-section="contact">Contact</a>
  </nav>
</header>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.nav-link');

  function setActive(id: string) {
    links.forEach(l => l.classList.toggle('nav-link--active', l.dataset.section === id));
  }

  const observer = new IntersectionObserver(
    entries => { entries.forEach(e => { if (e.isIntersecting) setActive(e.target.id); }); },
    { rootMargin: '-40% 0px -55% 0px' }
  );

  ['home', 'projects', 'contact'].forEach(id => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });

  setActive('home');
</script>

<style>
.nav-wrapper {
  position: sticky;
  top: 20px;
  z-index: 100;
  display: flex;
  justify-content: center;
  margin-top: 24px;
}

.navbar {
  display: inline-flex;
  align-items: center;
  gap: 2px;
  padding: 5px 6px;
  border-radius: 999px;
  background: rgba(10, 8, 20, 0.80);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.09);
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255,255,255,0.04);
}

.nav-link {
  position: relative;
  z-index: 1;
  display: inline-block;
  padding: 7px 18px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.01em;
  color: rgba(255, 255, 255, 0.45);
  text-decoration: none;
  transition: color 0.2s ease, background 0.2s ease;
  white-space: nowrap;
}

.nav-link:hover {
  color: rgba(255, 255, 255, 0.88);
  background: rgba(255, 255, 255, 0.06);
}

.nav-link--active {
  color: #fff;
  background: rgba(124, 58, 237, 0.20);
  box-shadow: inset 0 0 0 1px rgba(124, 58, 237, 0.30);
}

.nav-sep {
  display: block;
  width: 1px;
  height: 14px;
  background: rgba(255, 255, 255, 0.10);
  border-radius: 1px;
  flex-shrink: 0;
  margin: 0 1px;
}
</style>
